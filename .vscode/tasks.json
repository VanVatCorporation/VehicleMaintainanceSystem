{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build project",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-Wall",
                "-g",
                "main.c",
                "customer.c",
                "customer_validation.c",
                "repair.c",
                "fileio.c",
                "utils.c",
                "report.c",
                "-o",
                "${workspaceFolder}\\motorbike_shop.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the full project with gcc."
        },
        {
            "label": "Run Motorbike Shop",
            "type": "shell",
            "command": "${workspaceFolder}\\motorbike_shop.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "C/C++: gcc.exe build project",
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        }
    ],
    "version": "2.0.0"
}
