{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build VehicleMaintenanceSystem",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-Wall",
                "-g",
                "main.c",
                "customer.c",
                "repair.c",
                "fileio.c",
                "utils.c",
                "report.c",
                "-o",
                "motorbike_shop.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build all C source files in this project."
        },
        {
            "type": "shell",
            "label": "Run VehicleMaintenanceSystem",
            "command": ".\\motorbike_shop.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build VehicleMaintenanceSystem",
            "problemMatcher": [],
            "group": "test",
            "detail": "Run the compiled program in the terminal."
        }
    ]
}
